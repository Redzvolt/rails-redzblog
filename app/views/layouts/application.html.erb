<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails Redzblog" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" author="Cyril Faccin" keywords="">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Rails Redzblog">
    <meta name="mobile-web-app-capable" content="yes">
    <meta description="">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-4Q6Gf2aSP4eDXB8Miphtr37CMZZQ5oXLH2yaXMJ2w8e2ZtHTl7GptT4jmndRuHDT" crossorigin="anonymous">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="d-flex justify-content-between p-4 gap-4">
      <%= render "shared/navbar" %>
    </header>
    <%= render "shared/flashes" %>
    <%= yield %>
    <footer class="d-flex px-4">
      <div class="width_cinquante border-end border-black pe-4">
        <p>Créé par Redzvolt</p>
        <p>Retrouvez-moi sur mes réseaux : </p>
        <nav class="d-flex justify-content-between">
          <a href="https://www.linkedin.com/in/cyril-faccin/"><img src="app/assets/images/linkedin-logo-linkedin-logo-transparent-linkedin-icon-transparent-free-free-png.webp" alt="Logo linkedin" height="50px" target="_blank"></a>
          <a href="https://github.com/Redzvolt"><img src="app/assets/images/GitHub-Simbolo.png" alt="Logo Github" height="50px" target="_blank"></a>
        </nav>
      </div>
      <div class="width_cinquante ps-4">
        <%= link_to "Mentions légales", actualites_index_path %>
        <p>Les articles du site ont été rédigés par l'équipe du blog</p>
        <p>Les images appartiennent à leurs propriétaires respectifs</p>
        <p>Les actualités proviennent des institutions qui les organisent</p>
        <p>Cliquez sur le titre des mentions légales pour en savoir plus</p>
      </div>
    </footer>
  </body>
</html>
